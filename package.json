{
  "name": "tuidaw",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run index.ts",
    "check": "prettier --check . && tsc --noEmit && vue-tsc --noEmit -p web/tsconfig.json",
    "format": "prettier --write .",
    "test": "bun test",
    "setup": "bash setup.sh && bash native/build-wasm.sh",
    "build": "bun run check && bun test && bash native/build.sh && bash native/build-wasm.sh",
    "dev": "vite --config web/vite.config.ts",
    "build:web": "vite build --config web/vite.config.ts"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/bun": "latest",
    "@vitejs/plugin-vue": "^6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "vite": "^6",
    "vue-tsc": "^2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.1.88",
    "lucide": "^0.577.0",
    "vue": "3.6.0-beta.8"
  }
}
